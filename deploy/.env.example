# docker-compose env — copy to the repo root as `.env` and fill in (never commit it).
#   cp deploy/.env.example .env

# --- Postgres ---
POSTGRES_USER=anyramp
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=anyramp

# --- Backend ---
# Your deployed frontend origin(s), comma-separated. e.g. https://anyramp.vercel.app
CORS_ORIGIN=https://anyramp.vercel.app

# Pakasir production creds (dashboard)
PAKASIR_PROJECT=anyramp
PAKASIR_API_KEY=

# Reclaim (dev.reclaimprotocol.org)
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=

# Stellar — server key that submits txs; escrow the USDC is locked in.
# Current testnet escrow: CAS2EVVGSSKZADUTCHQESIXBDLTTIA3KEJYPPJXCQNAM5UJQGSISLBSB
SUBMITTER_SECRET=
ESCROW_CONTRACT_ID=CAS2EVVGSSKZADUTCHQESIXBDLTTIA3KEJYPPJXCQNAM5UJQGSISLBSB
# Defaults (backend) are testnet USDC + Reclaim verifier; override for other envs.
# USDC_CONTRACT_ID=CCPJ56XM7KNWKJEGEGE3YZA55RSB7GF2DOT47DA2NTBJLYZBNMJD6XCL
# RECLAIM_VERIFIER_ID=CAHEWTDHSWRJOBUD2FZ4UDGVF7PFW53W6RZ2G3O57DONSKWKXIYSZGGQ
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# --- Attestor witness key ---
# secp256k1 private key (0x…). Its ETH address MUST be registered on the verifier via
# add_epoch. For AnyRamp that address is 0x93f58be9dde2635e64538ec1d1be9a16cb03618c.
ATTESTOR_PRIVATE_KEY=
