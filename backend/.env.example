# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- Database (docker-compose brings this up on 5433) ---
DATABASE_URL=postgres://anyramp:anyramp@localhost:5433/anyramp

# --- Pakasir (point BASE_URL at the mock until real sandbox creds arrive) ---
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_PROJECT=
PAKASIR_API_KEY=

# --- Reclaim zkFetch (free: https://dev.reclaimprotocol.org) ---
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=

# --- Stellar ---
ESCROW_CONTRACT_ID=
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# --- Mock Pakasir (dev only) ---
MOCK_PORT=4990
WEBHOOK_URL=http://localhost:4000/webhook/pakasir
