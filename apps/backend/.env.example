# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
# Comma-separated allowed browser origins. '*' is dev-only; set your frontend URL in prod.
CORS_ORIGIN=*

# --- Database ---
DATABASE_URL=postgres://anyramp:anyramp@localhost:5432/anyramp

# --- Pakasir (production creds from the Pakasir dashboard) ---
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_PROJECT=
PAKASIR_API_KEY=

# --- Reclaim (free: https://dev.reclaimprotocol.org) ---
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=

# --- Self-hosted attestor (leave empty to use the public Reclaim attestor) ---
# Local docker: ws://localhost:8001/ws  ·  compose: ws://attestor:8001/ws  ·  prod: wss://attestor.yourdomain/ws
ATTESTOR_WS=
# Node 20+ binary for the isolated Reclaim prover ('' => `node` on PATH).
# Leave empty locally; Docker sets /usr/bin/node.
PROVE_NODE_BIN=

# --- Stellar ---
SUBMITTER_SECRET=
ESCROW_CONTRACT_ID=
USDC_CONTRACT_ID=CCPJ56XM7KNWKJEGEGE3YZA55RSB7GF2DOT47DA2NTBJLYZBNMJD6XCL
RECLAIM_VERIFIER_ID=CAHEWTDHSWRJOBUD2FZ4UDGVF7PFW53W6RZ2G3O57DONSKWKXIYSZGGQ
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# --- Settlement worker (server-side, so settlement never depends on a browser tab) ---
ENABLE_SETTLEMENT_WORKER=true
SETTLEMENT_POLL_MS=20000
