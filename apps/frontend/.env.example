# Backend API base URL. Local: http://localhost:4000 · prod: https://<your-backend-domain>
VITE_API_URL=http://localhost:4000

# Privy app ID for email embedded Stellar wallets.
# Dashboard: enable Email login + Stellar (extended chain). Passkey signup is optional.
# Leave empty to use local demo wallets (email + WebAuthn passkey).
VITE_PRIVY_APP_ID=cmgv5dwz100pyjv0cf8x2n0xc

# Stellar network for wallet kit: mainnet | testnet
VITE_STELLAR_NETWORK=testnet
